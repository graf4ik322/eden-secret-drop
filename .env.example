# ===== EDEN Secret Drop — Environment =====

# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=6398821843

# Domain (для Mini App + вебхука)
DOMAIN=secretdrop-app.edencore.cc

# Для разработки — включает dev-режим (admin bypass через x-admin-id header)
DEV_MODE=true

# JWT Secret — для подписи access/refresh токенов
JWT_SECRET=your-jwt-secret-change-in-production

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# Опционально — DATABASE_URL и REDIS_URL собираются автоматически в docker-compose
