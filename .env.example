# ===== EDEN Secret Drop — Environment Variables =====

# Telegram
BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789,987654321
WEBHOOK_URL=https://your-domain.com
MINI_APP_URL=https://eden-secret-drop.pages.dev

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eden_secret_drop

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
BOT_PORT=3002
HOST=0.0.0.0
NODE_ENV=development

# Storage (S3-compatible)
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_key
R2_SECRET_ACCESS_KEY=your_secret
R2_BUCKET=eden-drops
R2_PUBLIC_URL=https://cdn.edensecretdrop.com
